 --- BIN FILE READ: NICA_Gold
  10913 INCLUDE 'NICA_Gold';
  10914   PROCEDURE MCMCALC ALPHA0 ALPHA1;
  10915     VARIABLE TMPALPHA 100;
  10916     VARIABLE I 1;
  10917     VARIABLE MCM0 1;
  10918     VARIABLE MCM1 1;
  10919     VARIABLE MCM2 1;
  10920     VARIABLE MCM3 1;
  10921     VARIABLE MCM4 1;
  10922     MCM MAP SPOS TMPALPHA; %MCM: 3587
  10923     MCM0 := -TMPALPHA|(0&0&0&0&0&0);
  10924     MCM1 := -TMPALPHA|(0&0&0&0&0&1);
  10925     MCM2 := -2*TMPALPHA|(0&0&0&0&0&2);
  10926     MCM3 := -2*3*TMPALPHA|(0&0&0&0&0&3);
  10927     MCM4 := -2*3*4*TMPALPHA|(0&0&0&0&0&4);
  10928     ALPHA0:= MCM1;
  10929     ALPHA1:= MCM2;
  10930     WRITE 6 '++++++++ MOMENTUM COMPACTION FACTOR ++++++++';
  10931     WRITE 6 'MC0 = '&ST(MCM0);
  10932     WRITE 6 'MC1 = '&ST(MCM1);
  10933     WRITE 6 'MC2 = '&ST(MCM2);
  10934     WRITE 6 'MC3 = '&ST(MCM3);
  10935     WRITE 6 'MC4 = '&ST(MCM4);
  10936     WRITE 6 '++++++++++++++++++++++++++++++++++++++++++++';
  10937     ENDPROCEDURE;
  10938   PROCEDURE OPTIMIZE_CHROM SEXTGX1 SEXTGY1;
  10939     VARIABLE OBJ 1;
  10940     VARIABLE SGX1 1;
  10941     VARIABLE SGY1 1;
  10942     VARIABLE GAMMA 1;
  10943     VARIABLE CHROM_X 1;
  10944     VARIABLE CHROM_Y 1;
  10945     VARIABLE MU_TP 800 3;
  10946     WRITE 6 'BEGIN';
  10947     SGX1 := SEXTGX1;
  10948     SGY1 := SEXTGY1;
  10949     WRITE 6 'SGx1, SGy1 = '&ST(SGX1)&' '&ST(SGY1);
  10950     GAMMA := 7.040;
  10951     FIT SGX1 SGY1;
  10952       LATTICE SGX1 SGY1 1 0; %LATTICE:10580
  10953       TP MU_TP; %TP: 3955
  10954       CHROM_X := (MU_TP(1)|(0&0&0&0&1))*(1+1/GAMMA);
  10955       CHROM_Y := (MU_TP(2)|(0&0&0&0&1))*(1+1/GAMMA);
  10956       OBJ := SQRT(SQR(CHROM_X) + SQR(CHROM_Y));
  10957       WRITE 6 'SGx1, SGy1 = '&ST(SGX1)&' '&ST(SGY1);
  10958       WRITE 6 'CHROM_X, CHROM_Y='&ST(CHROM_X)&' '&ST(CHROM_Y);
  10959       WRITE 6 'OBJ ='&ST(OBJ);
  10960       ENDFIT 1E-12 2000 1 OBJ;
  10961     WRITE 6 '====================================';
  10962     WRITE 6 'SGx1, SGy1 = '&ST(SGX1)&' '&ST(SGY1);
  10963     WRITE 6 'CHROM_X, CHROM_Y='&ST(CHROM_X)&' '&ST(CHROM_Y);
  10964     WRITE 6 'OBJ ='&ST(OBJ);
  10965     SEXTGX1 := SGX1;
  10966     SEXTGY1 := SGY1;
  10967     ENDPROCEDURE;
  10968   PROCEDURE MAIN;
  10969     VARIABLE GAMMA 1;
  10970     VARIABLE SGX1 1;
  10971     VARIABLE SGY1 1;
  10972     GAMMA := 7.040;
  10973     OV 3 2 1; %OV:  969
  10974     SET_FOR_PROTONS GAMMA; %SET_FOR_PROTONS:10543
  10975     SGX1 := 0.0;
  10976     SGY1 := 0.0;
  10977     WRITE 6 'SGx1, SGy1 = '&ST(SGX1)&' '&ST(SGY1);
  10978     OPTIMIZE_CHROM SGX1 SGY1; %OPTIMIZE_CHROM:10938
  10979     WRITE 6 'SGx1 := '&ST(SGX1)&';';
  10980     WRITE 6 'SGy1 := '&ST(SGY1)&';';
  10981     ENDPROCEDURE;
  10982   PROCEDURE RUN;
  10983     MAIN; %MAIN:10968
  10984     ENDPROCEDURE;
  10985   RUN; %RUN:10982
