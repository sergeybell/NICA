 --- BIN FILE READ: NICA_Gold_maps
  11455 INCLUDE 'NICA_Gold_maps';
  11456   PROCEDURE PICK INDEX MAPARR SPNRARR;
  11457     VARIABLE I 1;
  11458     VARIABLE J 1;
  11459     LOOP I 1 TWOND;
  11460       MSC(I) := MAPARR(I, INDEX);
  11461       ENDLOOP;
  11462     LOOP I 1 3;
  11463       LOOP J 1 3;
  11464         SSCR(I,J) := SPNRARR(I,J,INDEX) + 0*DD(1);
  11465         ENDLOOP;
  11466       ENDLOOP;
  11467     ENDPROCEDURE;
  11468   PROCEDURE MAKEMAP FROM TO START MAPARR SPNRARR;
  11469     VARIABLE J 1;
  11470     WRITE 6 '* '&ST(START);
  11471     LMAPS START MAPARR SPNRARR; %LMAPS:10125
  11472     LOOP J (START+1) TO;
  11473       WRITE 6 '**       '&ST(J);
  11474       PICK J MAPARR SPNRARR; %PICK:11456
  11475       LOCSET 0 0 0 0 0 0; %LOCSET: 1114
  11476       UPDATE 1 1; %UPDATE: 1261
  11477       ENDLOOP;
  11478     LOOP J FROM (START-1);
  11479       WRITE 6 '**       '&ST(J);
  11480       PICK J MAPARR SPNRARR; %PICK:11456
  11481       LOCSET 0 0 0 0 0 0; %LOCSET: 1114
  11482       UPDATE 1 1; %UPDATE: 1261
  11483       ENDLOOP;
  11484     ENDPROCEDURE;
  11485   PROCEDURE GETTWISS0 COORD AL0 BET0 GAM0 MAPARR SPNRARR;
  11486     VARIABLE NUM1 1;
  11487     VARIABLE NUM2 1;
  11488     VARIABLE OBJ 1;
  11489     IF COORD='X';
  11490       NUM1:=1;
  11491       NUM2:=2;
  11492       AL0:=0;
  11493       BET0:=20.0;
  11494       GAM0:=1.0/BET0;
  11495       ELSEIF COORD='Y';
  11496       NUM1:=3;
  11497       NUM2:=4;
  11498       AL0:=0;
  11499       BET0:=3;
  11500       GAM0:=1.0/BET0;
  11501       ELSEIF LO(1);
  11502       WRITE 6 'UNKNOWN COORDINATE';
  11503       ENDIF;
  11504     FIT AL0 BET0 GAM0;
  11505       OBJ:= SQR(SQR(ME(NUM1,NUM1))*BET0-2*ME(NUM1,NUM1)*ME(NUM1,NUM2)*
                  AL0+SQR(ME(NUM1,NUM2))*GAM0-BET0); %ME:  516 %ME:  516 %ME: 
                   516 %ME:  516
  11506       OBJ:=OBJ+ SQR(-ME(NUM1,NUM1)*ME(NUM2,NUM1)*BET0+( ME(NUM1,NUM1)*
                  ME(NUM2,NUM2)+ME(NUM1,NUM2)*ME(NUM2,NUM1) )*AL0-ME(NUM1,NUM2
                  )*ME(NUM2,NUM2)*GAM0-AL0); %ME:  516 %ME:  516 %ME:  516 %ME
                  :  516 %ME:  516 %ME:  516 %ME:  516 %ME:  516
  11507       OBJ:=OBJ+ SQR((ME(NUM2,NUM1)^2)*BET0-2*ME(NUM2,NUM1)*ME(NUM2,NUM
                  2)*AL0+(ME(NUM2,NUM2)^2)*GAM0-(1+AL0^2)/BET0)  ; %ME:  516 %
                  ME:  516 %ME:  516 %ME:  516
  11508       ENDFIT 1E-20 5000 1 OBJ;
  11509     ENDPROCEDURE;
  11510   PROCEDURE BETS TAG COORD NUM_ELE AL0 BET0 GAM0 BETS MAPARR SPNRARR;
  11511     VARIABLE J 1;
  11512     VARIABLE NUM1 1;
  11513     VARIABLE NUM2 1;
  11514     IF COORD='X';
  11515       NUM1:=1;
  11516       NUM2:=2;
  11517       ELSEIF COORD='Y';
  11518       NUM1:=3;
  11519       NUM2:=4;
  11520       ELSEIF LO(1);
  11521       WRITE 6 'UNKNOWN COORDINATE';
  11522       ENDIF;
  11523     UM; %UM: 1488
  11524     BETS(1):=BET0;
  11525     OPENF 800 TAG 'REPLACE';
  11526     WRITE 800 ST(BETS(1))&'     '&ST(0);
  11527     LOOP J 1 NUM_ELE;
  11528       MAKEMAP 1 J 1 MAPARR SPNRARR; %MAKEMAP:11468
  11529       BETS(J+1):=(ME(NUM1,NUM1)^2)*BET0-2*ME(NUM1,NUM1)*ME(NUM1,NUM2)*
                  AL0+(ME(NUM1,NUM2)^2)*GAM0; %ME:  516 %ME:  516 %ME:  516 %M
                  E:  516
  11530       WRITE 800 ST(BETS(J+1))&'     '&ST(J);
  11531       UM; %UM: 1488
  11532       ENDLOOP;
  11533     CLOSEF 800;
  11534     ENDPROCEDURE;
  11535   PROCEDURE GETDISP0 COORD D0 DPR0 MAPARR SPNRARR;
  11536     VARIABLE NUM1 1;
  11537     VARIABLE NUM2 1;
  11538     VARIABLE OBJ 1;
  11539     IF COORD='X';
  11540       NUM1:=1;
  11541       NUM2:=2;
  11542       D0:=0;
  11543       DPR0:=0;
  11544       ELSEIF COORD='Y';
  11545       NUM1:=3;
  11546       NUM2:=4;
  11547       D0:=0;
  11548       DPR0:=0;
  11549       ELSEIF LO(1);
  11550       WRITE 6 'UNKNOWN COORDINATE';
  11551       ENDIF;
  11552     FIT D0 DPR0;
  11553       OBJ:= SQR(  ME(NUM1,NUM1)*D0+ME(NUM1,NUM2)*DPR0+ME(NUM1,6)*(1+1/
                  (CONS(ETA)+1))-D0  ); %ME:  516 %ME:  516 %ME:  516
  11554       OBJ:=OBJ+ SQR(  ME(NUM2,NUM1)*D0+ME(NUM2,NUM2)*DPR0+ME(NUM2,6)*(
                  1+1/(CONS(ETA)+1))-DPR0  )  ; %ME:  516 %ME:  516 %ME:  516
  11555       ENDFIT 1E-20 5000 1 OBJ;
  11556     WRITE 6 'DISP'&COORD&'0' 'DISP_PRIME'&COORD&'0';
  11557     WRITE 6 D0 DPR0;
  11558     ENDPROCEDURE;
  11559   PROCEDURE DISPS TAG COORD NUM_ELE D0 DPR0 DS MAPARR SPNRARR;
  11560     VARIABLE J 1;
  11561     VARIABLE NUM1 1;
  11562     VARIABLE NUM2 1;
  11563     IF COORD='X';
  11564       NUM1:=1;
  11565       NUM2:=2;
  11566       ELSEIF COORD='Y';
  11567       NUM1:=3;
  11568       NUM2:=4;
  11569       ELSEIF LO(1);
  11570       WRITE 6 'UNKNOWN COORDINATE';
  11571       ENDIF;
  11572     UM; %UM: 1488
  11573     DS(1):=D0;
  11574     OPENF 800 TAG 'REPLACE';
  11575     WRITE 800 ST(DS(1))&'     '&ST(0);
  11576     LOOP J 1 NUM_ELE;
  11577       MAKEMAP 1 J 1 MAPARR SPNRARR; %MAKEMAP:11468
  11578       DS(J+1):=ME(NUM1,NUM1)*D0+ME(NUM1,NUM2)*DPR0+ ME(NUM1,6)*(1+1/(C
                  ONS(ETA)+1)); %ME:  516 %ME:  516 %ME:  516
  11579       WRITE 800 ST(DS(J+1))&'     '&ST(J);
  11580       UM; %UM: 1488
  11581       ENDLOOP;
  11582     CLOSEF 800;
  11583     ENDPROCEDURE;
  11584   PROCEDURE MAIN;
  11585     VARIABLE GAMMA 1;
  11586     VARIABLE SGX1 1;
  11587     VARIABLE SGX2 1;
  11588     VARIABLE SGY1 1;
  11589     VARIABLE SGY2 1;
  11590     VARIABLE EB1 1;
  11591     VARIABLE ALPHAX0 1;
  11592     VARIABLE BETAX0 1;
  11593     VARIABLE GAMMAX0 1;
  11594     VARIABLE BETAXS 1 313;
  11595     VARIABLE ALPHAY0 1;
  11596     VARIABLE BETAY0 1;
  11597     VARIABLE GAMMAY0 1;
  11598     VARIABLE BETAYS 1 313;
  11599     VARIABLE DISPX0 1;
  11600     VARIABLE DISPXPR0 1;
  11601     VARIABLE DISPXS 1 313;
  11602     VARIABLE DISPY0 1;
  11603     VARIABLE DISPYPR0 1;
  11604     VARIABLE DISPYS 1 313;
  11605     VARIABLE MAPARR1 1000 6 313;
  11606     VARIABLE SPNRARR1 1000 3 3 313;
  11607     VARIABLE NUM_ELE 1;
  11608     GAMMA := 1.12792344429;
  11609     NUM_ELE := 272;
  11610     OV 3 3 0; %OV:  969
  11611     SET_FOR_DEUTERONS GAMMA; %SET_FOR_DEUTERONS:10561
  11612     EB1 := 0.0;
  11613     SGX1 :=  0.0;
  11614     SGY1  := 0.0;
  11615     SGX2 :=  0.0;
  11616     SGY2  := 0.0;
  11617     ALPHAX0:=-0.764426;
  11618     BETAX0:=8.54379;
  11619     GAMMAX0:=(1+SQR(ALPHAX0))/BETAX0;
  11620     ALPHAY0:=1.50582;
  11621     BETAY0:=14.6165;
  11622     GAMMAY0:=(1+SQR(ALPHAY0))/BETAY0;
  11623     DISPX0:=0.000111426;
  11624     DISPXPR0:=0.0;
  11625     DISPY0:=0.0;
  11626     DISPYPR0:=0.0;
  11627     LATTICE SGX1 SGY1 EB1 0 MAPARR1 SPNRARR1; %LATTICE:10580
  11628     PM 6; %PM: 1574
  11629     WRITE 6 '++++++++++ Magnetic Rigidity';
  11630     WRITE 6 CONS(CHIM);
  11631     WRITE 6 ME(3,6); %ME:  516
  11632     DISPS 'DISPX' 'X' NUM_ELE DISPX0 DISPXPR0 DISPXS MAPARR1 SPNRARR1;
                   %DISPS:11559
  11633     ENDPROCEDURE;
  11634   PROCEDURE RUN;
  11635     MAIN; %MAIN:11584
  11636     ENDPROCEDURE;
  11637   RUN; %RUN:11634
