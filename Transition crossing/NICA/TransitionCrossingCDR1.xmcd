		<region region-id="12562" left="342" top="4928.25" width="221.25" height="60.75" align-x="402.75" align-y="4944" show-border="false" show-highlight="false" is-protected="true" z-order="0" background-color="inherit" tag="">
			<math optimize="false" disable-calc="false">
				<ml:define xmlns:ml="http://schemas.mathsoft.com/math30">
					<ml:function>
						<ml:id xml:space="preserve">CorPhase</ml:id>
						<ml:boundVars>
							<ml:id xml:space="preserve">nt</ml:id>
						</ml:boundVars>
					</ml:function>
					<ml:program>
						<ml:localDefine>
							<ml:id xml:space="preserve">r</ml:id>
							<ml:apply>
								<ml:plus/>
								<ml:apply>
									<ml:mult/>
									<ml:apply>
										<ml:neg/>
										<ml:apply>
											<ml:indexer/>
											<ml:id xml:space="preserve">BP</ml:id>
											<ml:sequence>
												<ml:id xml:space="preserve">nt</ml:id>
												<ml:real>1</ml:real>
											</ml:sequence>
										</ml:apply>
									</ml:apply>
									<ml:apply>
										<ml:div/>
										<ml:real>180</ml:real>
										<ml:id xml:space="preserve">π</ml:id>
									</ml:apply>
								</ml:apply>
								<ml:apply>
									<ml:mult/>
									<ml:real>360</ml:real>
									<ml:parens>
										<ml:apply>
											<ml:greaterThan/>
											<ml:apply>
												<ml:indexer/>
												<ml:id xml:space="preserve">ηs</ml:id>
												<ml:id xml:space="preserve">nt</ml:id>
											</ml:apply>
											<ml:real>0</ml:real>
										</ml:apply>
									</ml:parens>
								</ml:apply>
							</ml:apply>
						</ml:localDefine>
						<ml:ifThen>
							<ml:apply>
								<ml:greaterThan/>
								<ml:id xml:space="preserve">r</ml:id>
								<ml:real>180</ml:real>
							</ml:apply>
							<ml:localDefine>
								<ml:id xml:space="preserve">r</ml:id>
								<ml:apply>
									<ml:minus/>
									<ml:id xml:space="preserve">r</ml:id>
									<ml:real>360</ml:real>
								</ml:apply>
							</ml:localDefine>
						</ml:ifThen>
						<ml:id xml:space="preserve">r</ml:id>
					</ml:program>
				</ml:define>
			</math>
