									<ml:id xml:space="preserve" subscript="bi">N</ml:id>
								</ml:apply>
								<ml:apply>
									<ml:indexer/>
									<ml:id xml:space="preserve" subscript="RF">f</ml:id>
									<ml:id xml:space="preserve" subscript="ref">n</ml:id>
								</ml:apply>
							</ml:apply>
							<ml:id xml:space="preserve">q</ml:id>
						</ml:apply>
						<ml:apply>
							<ml:indexer/>
							<ml:id xml:space="preserve">B</ml:id>
							<ml:id xml:space="preserve">nt</ml:id>
						</ml:apply>
					</ml:apply>
				</ml:define>
