		<region region-id="18202" left="6" top="14916" width="174" height="51" align-x="41.25" align-y="14940" show-border="false" show-highlight="false" is-protected="true" z-order="0" background-color="inherit" tag="">
			<math optimize="false" disable-calc="false">
				<ml:define xmlns:ml="http://schemas.mathsoft.com/math30">
					<ml:apply>
						<ml:indexer/>
						<ml:id xml:space="preserve" subscript="min">η</ml:id>
						<ml:id xml:space="preserve">nt</ml:id>
					</ml:apply>
					<ml:apply>
						<ml:div/>
						<ml:apply>
							<ml:mult/>
							<ml:apply>
								<ml:indexer/>
								<ml:id xml:space="preserve" subscript="peak">I</ml:id>
								<ml:id xml:space="preserve">nt</ml:id>
							</ml:apply>
							<ml:apply>
								<ml:id xml:space="preserve">Znn</ml:id>
								<ml:apply>
									<ml:indexer/>
									<ml:id xml:space="preserve">γ</ml:id>
									<ml:id xml:space="preserve">nt</ml:id>
								</ml:apply>
							</ml:apply>
						</ml:apply>
						<ml:apply>
							<ml:mult/>
							<ml:apply>
								<ml:mult/>
								<ml:apply>
									<ml:mult/>
									<ml:apply>
										<ml:mult/>
										<ml:apply>
											<ml:mult/>
											<ml:real>2</ml:real>
											<ml:id xml:space="preserve">π</ml:id>
										</ml:apply>
										<ml:id xml:space="preserve" subscript="p">m</ml:id>
									</ml:apply>
									<ml:apply>
										<ml:indexer/>
										<ml:id xml:space="preserve">γ</ml:id>
										<ml:id xml:space="preserve" subscript="tr">n</ml:id>
									</ml:apply>
								</ml:apply>
								<ml:apply>
									<ml:pow/>
									<ml:parens>
										<ml:apply>
											<ml:indexer/>
											<ml:id xml:space="preserve">β</ml:id>
											<ml:id xml:space="preserve" subscript="tr">n</ml:id>
										</ml:apply>
									</ml:parens>
									<ml:real>2</ml:real>
								</ml:apply>
							</ml:apply>
							<ml:apply>
								<ml:pow/>
								<ml:parens>
									<ml:apply>
										<ml:indexer/>
										<ml:id xml:space="preserve">BP</ml:id>
										<ml:sequence>
											<ml:id xml:space="preserve">nt</ml:id>
											<ml:real>4</ml:real>
										</ml:sequence>
									</ml:apply>
								</ml:parens>
								<ml:real>2</ml:real>
							</ml:apply>
						</ml:apply>
					</ml:apply>
				</ml:define>
			</math>
