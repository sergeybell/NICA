		<region region-id="18247" left="354" top="5755.5" width="183" height="25.5" align-x="387.75" align-y="5772" show-border="false" show-highlight="false" is-protected="true" z-order="0" background-color="inherit" tag="">
			<math optimize="false" disable-calc="false">
				<ml:define xmlns:ml="http://schemas.mathsoft.com/math30">
					<ml:apply>
						<ml:indexer/>
						<ml:id xml:space="preserve">εrms</ml:id>
						<ml:id xml:space="preserve">nt</ml:id>
					</ml:apply>
					<ml:apply>
						<ml:sqrt/>
						<ml:apply>
							<ml:minus/>
							<ml:apply>
								<ml:mult/>
								<ml:apply>
									<ml:pow/>
									<ml:parens>
										<ml:apply>
											<ml:indexer/>
											<ml:id xml:space="preserve">BP</ml:id>
											<ml:sequence>
												<ml:id xml:space="preserve">nt</ml:id>
												<ml:real>3</ml:real>
											</ml:sequence>
										</ml:apply>
									</ml:parens>
									<ml:real>2</ml:real>
								</ml:apply>
								<ml:apply>
									<ml:pow/>
									<ml:parens>
										<ml:apply>
											<ml:indexer/>
											<ml:id xml:space="preserve">BP</ml:id>
											<ml:sequence>
												<ml:id xml:space="preserve">nt</ml:id>
												<ml:real>4</ml:real>
											</ml:sequence>
										</ml:apply>
									</ml:parens>
									<ml:real>2</ml:real>
								</ml:apply>
							</ml:apply>
							<ml:apply>
								<ml:pow/>
								<ml:parens>
									<ml:apply>
										<ml:indexer/>
										<ml:id xml:space="preserve">BP</ml:id>
										<ml:sequence>
											<ml:id xml:space="preserve">nt</ml:id>
											<ml:real>9</ml:real>
										</ml:sequence>
									</ml:apply>
								</ml:parens>
								<ml:real>2</ml:real>
							</ml:apply>
						</ml:apply>
					</ml:apply>
				</ml:define>
			</math>
			<rendering item-idref="373"/>
		</region>
