		<region region-id="17370" left="186" top="3321" width="385.5" height="218.25" align-x="249.75" align-y="3330" show-border="false" show-highlight="false" is-protected="true" z-order="-106" background-color="inherit" tag="">
			<math optimize="false" disable-calc="false">
				<ml:define xmlns:ml="http://schemas.mathsoft.com/math30">
					<ml:function>
						<ml:id xml:space="preserve">Phase</ml:id>
						<ml:boundVars>
							<ml:id xml:space="preserve" subscript="in">φRF</ml:id>
						</ml:boundVars>
					</ml:function>
					<ml:program>
						<ml:localDefine>
							<ml:id xml:space="preserve">i</ml:id>
							<ml:real>0</ml:real>
						</ml:localDefine>
						<ml:localDefine>
							<ml:id xml:space="preserve">t</ml:id>
							<ml:real>0</ml:real>
						</ml:localDefine>
						<ml:for>
							<ml:id xml:space="preserve">n</ml:id>
							<ml:range>
								<ml:real>0</ml:real>
								<ml:apply>
									<ml:id xml:space="preserve">floor</ml:id>
									<ml:apply>
										<ml:mult/>
										<ml:id xml:space="preserve" subscript="B">f</ml:id>
										<ml:id xml:space="preserve" subscript="inj">T</ml:id>
									</ml:apply>
								</ml:apply>
							</ml:range>
							<ml:program>
								<ml:localDefine>
									<ml:id xml:space="preserve">t</ml:id>
									<ml:apply>
										<ml:mult/>
										<ml:id xml:space="preserve" subscript="B">T</ml:id>
										<ml:id xml:space="preserve">n</ml:id>
									</ml:apply>
								</ml:localDefine>
								<ml:localDefine>
									<ml:id xml:space="preserve">φ</ml:id>
									<ml:apply>
										<ml:minus/>
										<ml:apply>
											<ml:mult/>
											<ml:apply>
												<ml:mult/>
												<ml:real>2</ml:real>
												<ml:id xml:space="preserve">π</ml:id>
											</ml:apply>
											<ml:parens>
												<ml:apply>
													<ml:minus/>
													<ml:parens>
														<ml:apply>
															<ml:div/>
															<ml:apply>
																<ml:plus/>
																<ml:id xml:space="preserve" subscript="in">φRF</ml:id>
																<ml:apply>
																	<ml:mult/>
																	<ml:apply>
																		<ml:mult/>
																		<ml:apply>
																			<ml:mult/>
																			<ml:real>2</ml:real>
																			<ml:id xml:space="preserve">π</ml:id>
																		</ml:apply>
																		<ml:apply>
																			<ml:indexer/>
																			<ml:id xml:space="preserve">f0</ml:id>
																			<ml:real>0</ml:real>
																		</ml:apply>
																	</ml:apply>
																	<ml:id xml:space="preserve">t</ml:id>
																</ml:apply>
															</ml:apply>
															<ml:apply>
																<ml:mult/>
																<ml:real>2</ml:real>
																<ml:id xml:space="preserve">π</ml:id>
															</ml:apply>
														</ml:apply>
													</ml:parens>
													<ml:apply>
														<ml:id xml:space="preserve">floor</ml:id>
														<ml:parens>
															<ml:apply>
																<ml:div/>
																<ml:apply>
																	<ml:plus/>
																	<ml:id xml:space="preserve" subscript="in">φRF</ml:id>
																	<ml:apply>
																		<ml:mult/>
																		<ml:apply>
																			<ml:mult/>
																			<ml:apply>
																				<ml:mult/>
																				<ml:real>2</ml:real>
																				<ml:id xml:space="preserve">π</ml:id>
																			</ml:apply>
																			<ml:apply>
																				<ml:indexer/>
																				<ml:id xml:space="preserve">f0</ml:id>
																				<ml:real>0</ml:real>
																			</ml:apply>
																		</ml:apply>
																		<ml:id xml:space="preserve">t</ml:id>
																	</ml:apply>
																</ml:apply>
																<ml:apply>
																	<ml:mult/>
																	<ml:real>2</ml:real>
																	<ml:id xml:space="preserve">π</ml:id>
																</ml:apply>
															</ml:apply>
														</ml:parens>
													</ml:apply>
												</ml:apply>
											</ml:parens>
										</ml:apply>
										<ml:id xml:space="preserve">π</ml:id>
									</ml:apply>
								</ml:localDefine>
								<ml:ifThen>
									<ml:parens>
										<ml:apply>
											<ml:greaterThan/>
											<ml:apply>
												<ml:absval/>
												<ml:id xml:space="preserve">φ</ml:id>
											</ml:apply>
											<ml:apply>
												<ml:div/>
												<ml:id xml:space="preserve" subscript="max">φ</ml:id>
												<ml:id xml:space="preserve">q</ml:id>
											</ml:apply>
										</ml:apply>
									</ml:parens>
									<ml:continue/>
								</ml:ifThen>
								<ml:localDefine>
									<ml:apply>
										<ml:indexer/>
										<ml:id xml:space="preserve">r</ml:id>
										<ml:sequence>
											<ml:id xml:space="preserve">i</ml:id>
											<ml:real>0</ml:real>
										</ml:sequence>
									</ml:apply>
									<ml:apply>
										<ml:id xml:space="preserve">floor</ml:id>
										<ml:apply>
											<ml:mult/>
											<ml:apply>
												<ml:indexer/>
												<ml:id xml:space="preserve">f0</ml:id>
												<ml:real>0</ml:real>
											</ml:apply>
											<ml:id xml:space="preserve">t</ml:id>
										</ml:apply>
									</ml:apply>
								</ml:localDefine>
								<ml:localDefine>
									<ml:apply>
										<ml:indexer/>
										<ml:id xml:space="preserve">r</ml:id>
										<ml:sequence>
											<ml:id xml:space="preserve">i</ml:id>
											<ml:real>1</ml:real>
										</ml:sequence>
									</ml:apply>
									<ml:apply>
										<ml:mult/>
										<ml:id xml:space="preserve">q</ml:id>
										<ml:id xml:space="preserve">φ</ml:id>
									</ml:apply>
								</ml:localDefine>
								<ml:localDefine>
									<ml:id xml:space="preserve">i</ml:id>
									<ml:apply>
										<ml:plus/>
										<ml:id xml:space="preserve">i</ml:id>
										<ml:real>1</ml:real>
									</ml:apply>
								</ml:localDefine>
							</ml:program>
