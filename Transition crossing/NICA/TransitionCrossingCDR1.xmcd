		<region region-id="16637" left="6" top="13214.25" width="179.25" height="12" align-x="9.75" align-y="13224" show-border="false" show-highlight="false" is-protected="true" z-order="0" background-color="inherit" tag="">
			<text use-page-width="false" push-down="false" lock-width="false">
				<p style="Normal" margin-left="inherit" margin-right="inherit" text-indent="inherit" text-align="inherit" list-style-type="inherit" tabs="inherit">In the space outside of the beam we have</p>
			</text>
		</region>
		<region region-id="16599" left="6" top="13227" width="179.25" height="16.5" align-x="38.25" align-y="13236" show-border="false" show-highlight="false" is-protected="true" z-order="0" background-color="inherit" tag="">
			<math optimize="false" disable-calc="false">
				<ml:apply xmlns:ml="http://schemas.mathsoft.com/math30">
					<ml:equal/>
					<ml:apply>
						<ml:id xml:space="preserve">φ</ml:id>
						<ml:sequence>
							<ml:id xml:space="preserve">r</ml:id>
							<ml:id xml:space="preserve">z</ml:id>
						</ml:sequence>
					</ml:apply>
					<ml:apply>
						<ml:mult/>
						<ml:parens>
							<ml:apply>
								<ml:plus/>
								<ml:apply>
									<ml:mult/>
									<ml:id xml:space="preserve" subscript="1">a</ml:id>
									<ml:apply>
										<ml:id xml:space="preserve">K0</ml:id>
										<ml:apply>
											<ml:mult/>
											<ml:id xml:space="preserve">k</ml:id>
											<ml:id xml:space="preserve">r</ml:id>
										</ml:apply>
									</ml:apply>
								</ml:apply>
								<ml:apply>
									<ml:mult/>
									<ml:id xml:space="preserve" subscript="2">a</ml:id>
									<ml:apply>
										<ml:id xml:space="preserve">I0</ml:id>
										<ml:apply>
											<ml:mult/>
											<ml:id xml:space="preserve">k</ml:id>
											<ml:id xml:space="preserve">r</ml:id>
										</ml:apply>
									</ml:apply>
								</ml:apply>
							</ml:apply>
						</ml:parens>
						<ml:apply>
							<ml:id xml:space="preserve">cos</ml:id>
							<ml:apply>
								<ml:mult/>
								<ml:id xml:space="preserve">k</ml:id>
								<ml:id xml:space="preserve">z</ml:id>
							</ml:apply>
						</ml:apply>
					</ml:apply>
				</ml:apply>
			</math>
			<rendering item-idref="617"/>
		</region>
		<region region-id="16612" left="6" top="13250.25" width="266.25" height="12" align-x="13.5" align-y="13260" show-border="false" show-highlight="false" is-protected="true" z-order="0" background-color="inherit" tag="">
			<text use-page-width="false" push-down="false" lock-width="false">
				<p style="Normal" margin-left="inherit" margin-right="inherit" text-indent="inherit" text-align="inherit" list-style-type="inherit" tabs="inherit">One can test it substituting to Laplasian in cylindrical frame:<sp count="2"/>
				</p>
			</text>
		</region>
		<region region-id="16613" left="18" top="13267.5" width="403.5" height="37.5" align-x="409.5" align-y="13290" show-border="false" show-highlight="false" is-protected="true" z-order="0" background-color="inherit" tag="">
			<math optimize="false" disable-calc="false">
				<ml:apply xmlns:ml="http://schemas.mathsoft.com/math30">
					<ml:equal/>
					<ml:apply>
						<ml:plus/>
						<ml:apply>
							<ml:mult/>
							<ml:apply>
								<ml:div/>
								<ml:real>1</ml:real>
								<ml:id xml:space="preserve">r</ml:id>
							</ml:apply>
							<ml:parens>
								<ml:apply>
									<ml:derivative/>
									<ml:lambda>
										<ml:boundVars>
											<ml:id xml:space="preserve">r</ml:id>
										</ml:boundVars>
										<ml:parens>
											<ml:apply>
												<ml:mult/>
												<ml:id xml:space="preserve">r</ml:id>
												<ml:parens>
													<ml:apply>
														<ml:derivative/>
														<ml:lambda>
															<ml:boundVars>
																<ml:id xml:space="preserve">r</ml:id>
															</ml:boundVars>
															<ml:parens>
																<ml:apply>
																	<ml:mult/>
																	<ml:parens>
																		<ml:apply>
																			<ml:plus/>
																			<ml:apply>
																				<ml:mult/>
																				<ml:id xml:space="preserve" subscript="1">a</ml:id>
																				<ml:apply>
																					<ml:id xml:space="preserve">K0</ml:id>
																					<ml:apply>
																						<ml:mult/>
																						<ml:id xml:space="preserve">k</ml:id>
																						<ml:id xml:space="preserve">r</ml:id>
																					</ml:apply>
																				</ml:apply>
																			</ml:apply>
																			<ml:apply>
																				<ml:mult/>
																				<ml:id xml:space="preserve" subscript="2">a</ml:id>
																				<ml:apply>
																					<ml:id xml:space="preserve">I0</ml:id>
																					<ml:apply>
																						<ml:mult/>
																						<ml:id xml:space="preserve">k</ml:id>
																						<ml:id xml:space="preserve">r</ml:id>
																					</ml:apply>
																				</ml:apply>
																			</ml:apply>
																		</ml:apply>
																	</ml:parens>
																	<ml:apply>
																		<ml:id xml:space="preserve">cos</ml:id>
																		<ml:apply>
																			<ml:mult/>
																			<ml:id xml:space="preserve">k</ml:id>
																			<ml:id xml:space="preserve">z</ml:id>
																		</ml:apply>
																	</ml:apply>
																</ml:apply>
															</ml:parens>
														</ml:lambda>
													</ml:apply>
