		<region region-id="18201" left="6" top="14897.25" width="141.75" height="15.75" align-x="21.75" align-y="14910" show-border="false" show-highlight="false" is-protected="true" z-order="0" background-color="inherit" tag="">
			<text use-page-width="false" push-down="false" lock-width="true">
				<p style="Heading 2" margin-left="inherit" margin-right="inherit" text-indent="inherit" text-align="inherit" list-style-type="inherit" tabs="inherit">Stability boundary </p>
			</text>
